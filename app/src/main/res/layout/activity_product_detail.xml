<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="160dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#E0E0E0"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">
                <ImageView
                    android:id="@+id/btnBackDetail"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/menu" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Apple MeoMeo"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/shopping_cart_24" />
            </LinearLayout>

            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E0E0E0"
                android:paddingBottom="8dp">
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_search"
                    android:drawableStart="@drawable/search"
                    android:drawablePadding="10dp"
                    android:enabled="false"
                    android:hint="Bạn tìm gì..."
                    android:paddingHorizontal="12dp" />
            </LinearLayout>

            <!-- Product Image Section (To và Rõ) -->
            <ImageView
                android:id="@+id/imgDetailMain"
                android:layout_width="match_parent"
                android:layout_height="550dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_apple_logo" />

            <!-- Product Info Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp">

                <TextView
                    android:id="@+id/txtDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên sản phẩm"
                    android:textColor="#000000"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDetailPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="36.790.000đ"
                    android:textColor="#1976D2"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <!-- Giá cũ - ĐÃ ẨN -->
                <TextView
                    android:id="@+id/txtDetailOldPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="37.990.000đ"
                    android:textColor="#9E9E9E"
                    android:textSize="18sp"
                    android:visibility="gone" />

                <!-- Bảng Thông số kỹ thuật -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#F0F0F0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thông số kỹ thuật"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp"/>
                        <LinearLayout
                            android:id="@+id/specsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Đánh giá -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:text="Đánh giá sản phẩm"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <RatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:numStars="5"
                    style="?android:attr/ratingBarStyleSmall" />
                <EditText
                    android:id="@+id/edtComment"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_search"
                    android:gravity="top"
                    android:hint="Viết nhận xét của bạn..."
                    android:padding="10dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitReview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Gửi đánh giá"
                    app:backgroundTint="#FF6D00" />

                <!-- Sản phẩm liên quan -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:text="Sản phẩm liên quan"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRelated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingBottom="20dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FIXED BOTTOM BAR (Buttons + Footer) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:orientation="vertical">

        <!-- Purchase Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCartDetail"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="Thêm vào giỏ"
                android:textColor="@color/login_teal"
                app:strokeColor="@color/login_teal"
                app:cornerRadius="8dp" />
            <View android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuyNowDetail"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="MUA NGAY"
                android:textStyle="bold"
                app:backgroundTint="#FF5722"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- Fixed Black Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#1D1D1F"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPLE MEO MEO"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Hotline mua hàng: 0379819805 \n Hotline bảo hành: 0978255997"
                android:textColor="#E0E0E0"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>