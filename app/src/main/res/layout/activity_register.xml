<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/login_teal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="20dp">

        <ImageView
            android:id="@+id/btnBackRegister"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="Quay lại"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Tạo tài khoản mới"
            android:textColor="@android:color/white"
            android:textSize="24sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="26dp"
            android:paddingEnd="28dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhập tên của bạn"
                    android:textColor="@color/login_hint"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/edtShopName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Họ và tên"
                    android:paddingTop="8dp"
                    android:paddingBottom="12dp"
                    android:textColor="@android:color/black"
                    android:textColorHint="@color/login_hint"
                    android:textSize="17sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/login_line" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email (dùng để đăng nhập)"
                    android:textColor="@color/login_hint"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/edtRegisterEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Nhập email"
                    android:inputType="textEmailAddress"
                    android:paddingTop="8dp"
                    android:paddingBottom="12dp"
                    android:textColor="@android:color/black"
                    android:textColorHint="@color/login_hint"
                    android:textSize="17sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/login_line" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số điện thoại"
                    android:textColor="@color/login_hint"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/edtRegisterPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Nhập số điện thoại"
                    android:inputType="phone"
                    android:paddingTop="8dp"
                    android:paddingBottom="12dp"
                    android:textColor="@android:color/black"
                    android:textColorHint="@color/login_hint"
                    android:textSize="17sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/login_line" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edtRegisterPassword"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Mật khẩu"
                    android:inputType="textPassword"
                    android:paddingBottom="12dp"
                    android:textColor="@android:color/black"
                    android:textColorHint="@color/login_hint"
                    android:textSize="17sp" />

                <ImageView
                    android:id="@+id/imgToggleRegisterPassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Hiện hoặc ẩn mật khẩu"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="@color/login_hint" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/login_line" />

            <EditText
                android:id="@+id/edtConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:background="@null"
                android:hint="Nhập lại mật khẩu"
                android:inputType="textPassword"
                android:paddingBottom="12dp"
                android:textColor="@android:color/black"
                android:textColorHint="@color/login_hint"
                android:textSize="17sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/login_line" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="42dp"
                android:text="TẠO TÀI KHOẢN"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="19sp"
                android:textStyle="bold"
                app:backgroundTint="@color/login_teal"
                app:cornerRadius="8dp"
                app:elevation="4dp" />
        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="@color/login_teal" />

</LinearLayout>