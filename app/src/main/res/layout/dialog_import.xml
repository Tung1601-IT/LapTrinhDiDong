<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thông tin nhập hàng"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="15dp"
        android:textColor="#6200EE"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chọn sản phẩm:"/>
    <Spinner android:id="@+id/dialog_spProduct" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/dialog_etSupplier"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tên Nhà cung cấp"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/dialog_etPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Số điện thoại liên hệ"
        android:inputType="phone"
        android:layout_marginBottom="10dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <EditText
            android:id="@+id/dialog_etQty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Số lượng"
            android:inputType="number"
            android:layout_marginEnd="5dp"/>
        <EditText
            android:id="@+id/dialog_etImportPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Giá nhập"
            android:inputType="numberDecimal" />
    </LinearLayout>
</LinearLayout>